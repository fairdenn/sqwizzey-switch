<Window x:Class="SwizzeySwitch.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Swizzey Switch"
        Width="110" Height="80"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        Focusable="False"
        IsHitTestVisible="False"
        Opacity="0">
    <Grid>
        <Border x:Name="Card"
                Width="110" Height="80"
                CornerRadius="18"
                Background="#CC1E1E1E">
            <Border.Effect>
                <DropShadowEffect Color="Black"
                                  Opacity="0.45"
                                  BlurRadius="18"
                                  ShadowDepth="3"
                                  Direction="270" />
            </Border.Effect>
            <TextBlock x:Name="LangText"
                       Text="EN"
                       FontFamily="Segoe UI"
                       FontSize="34"
                       FontWeight="SemiBold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Border>
    </Grid>
</Window>
