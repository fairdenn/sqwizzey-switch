<Window x:Class="SwizzeySwitch.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Swizzey Switch — Settings"
        Width="370" Height="400"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        ShowActivated="True"
        FontFamily="Segoe UI"
        FontSize="12">

    <Grid Margin="14,12,14,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Overlay ── -->
        <GroupBox Grid.Row="0" Header="Overlay" Margin="0,0,0,8" Padding="8,6,8,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="52"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Duration:" VerticalAlignment="Center" Foreground="#555"/>
                <Slider    Grid.Row="0" Grid.Column="1" x:Name="SliderDuration"
                           Minimum="300" Maximum="2000" TickFrequency="100" IsSnapToTickEnabled="True"
                           VerticalAlignment="Center" Margin="4,0"
                           ValueChanged="SliderDuration_ValueChanged"/>
                <TextBlock Grid.Row="0" Grid.Column="2" x:Name="LblDuration" Text="800 ms"
                           VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="#555" FontSize="11"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Opacity:" VerticalAlignment="Center"
                           Foreground="#555" Margin="0,6,0,0"/>
                <Slider    Grid.Row="1" Grid.Column="1" x:Name="SliderOpacity"
                           Minimum="0.40" Maximum="1.00" TickFrequency="0.05" IsSnapToTickEnabled="True"
                           VerticalAlignment="Center" Margin="4,6,4,0"
                           ValueChanged="SliderOpacity_ValueChanged"/>
                <TextBlock Grid.Row="1" Grid.Column="2" x:Name="LblOpacity" Text="88%"
                           VerticalAlignment="Center" HorizontalAlignment="Right"
                           Foreground="#555" FontSize="11" Margin="0,6,0,0"/>
            </Grid>
        </GroupBox>

        <!-- ── Appearance ── -->
        <GroupBox Grid.Row="1" Header="Appearance" Margin="0,0,0,8" Padding="8,6,8,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="52"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Position:" VerticalAlignment="Center" Foreground="#555"/>
                <ComboBox  Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" x:Name="CbPosition"
                           Margin="4,0,0,0" Height="24">
                    <ComboBoxItem Content="Center"        Tag="Center"/>
                    <ComboBoxItem Content="Top Center"    Tag="TopCenter"/>
                    <ComboBoxItem Content="Bottom Center" Tag="BottomCenter"/>
                    <ComboBoxItem Content="Top Left"      Tag="TopLeft"/>
                    <ComboBoxItem Content="Top Right"     Tag="TopRight"/>
                    <ComboBoxItem Content="Bottom Left"   Tag="BottomLeft"/>
                    <ComboBoxItem Content="Bottom Right"  Tag="BottomRight"/>
                </ComboBox>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Offset Y:" VerticalAlignment="Center"
                           Foreground="#555" Margin="0,6,0,0"/>
                <Slider    Grid.Row="1" Grid.Column="1" x:Name="SliderOffsetY"
                           Minimum="-200" Maximum="200" TickFrequency="10" IsSnapToTickEnabled="True"
                           VerticalAlignment="Center" Margin="4,6,4,0"
                           ValueChanged="SliderOffsetY_ValueChanged"/>
                <TextBlock Grid.Row="1" Grid.Column="2" x:Name="LblOffsetY" Text="0 px"
                           VerticalAlignment="Center" HorizontalAlignment="Right"
                           Foreground="#555" FontSize="11" Margin="0,6,0,0"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Theme:" VerticalAlignment="Center"
                           Foreground="#555" Margin="0,6,0,0"/>
                <ComboBox  Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" x:Name="CbTheme"
                           Margin="4,6,0,0" Height="24">
                    <ComboBoxItem Content="Dark"          Tag="Dark"/>
                    <ComboBoxItem Content="Light"         Tag="Light"/>
                    <ComboBoxItem Content="Auto (system)" Tag="Auto"/>
                </ComboBox>
            </Grid>
        </GroupBox>

        <!-- ── Behavior ── -->
        <GroupBox Grid.Row="2" Header="Behavior" Margin="0,0,0,12" Padding="8,6,8,8">
            <StackPanel>
                <CheckBox x:Name="ChkSkipFullscreen" Content="Skip fullscreen apps (games)"
                          Foreground="#333" Margin="0,0,0,5"/>
                <CheckBox x:Name="ChkStartup"        Content="Start with Windows"
                          Foreground="#333"/>
            </StackPanel>
        </GroupBox>

        <!-- ── Buttons ── -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnPreview" Content="Preview"
                    Width="72" Height="26" Margin="0,0,6,0"
                    Click="BtnPreview_Click"/>
            <Button x:Name="BtnCancel" Content="Cancel"
                    Width="72" Height="26" Margin="0,0,6,0" IsCancel="True"
                    Click="BtnCancel_Click"/>
            <Button x:Name="BtnSave"   Content="Save"
                    Width="72" Height="26" IsDefault="True"
                    Click="BtnSave_Click"/>
        </StackPanel>

    </Grid>
</Window>
